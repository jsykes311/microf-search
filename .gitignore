# ── Ignore everything by default ────────────────────────────────────────────
*

# ── Then explicitly allow the app files ─────────────────────────────────────
!.gitignore
!.github/
!.github/**
!main.py
!requirements.txt
!static/
!static/**
!azure/
!azure/**

# ── Never allow secrets or caches, even inside static/ ──────────────────────
.env
__pycache__/
*.pyc
*.pyo
.DS_Store
